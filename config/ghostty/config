# $HOME/Library/Application Support/com.mitchellh.ghostty/config

# Run `ghostty +show-config --default --docs` to view a list of
# all available config options and their default values.

# Additionally, each config option is also explained in detail
# on Ghostty's website, at https://ghostty.org/docs/config.

# Config
# ==========================
font-family = "Maple Mono"
font-thicken = true
font-size = 14.5
adjust-cell-height = 3
# theme = Chester
# theme = Terafox
# theme = Synthwave Alpha
# theme = Spacedust
# theme = Rebecca
 theme = Purplepeter
# theme = One Dark Two
window-padding-x = 5

# Keybinds
# ==========================

# Swap cmd+c and ctrl+c: cmd+c sends interrupt, ctrl+c copies
keybind = cmd+c=text:\x03
keybind = ctrl+c=copy_to_clipboard

# Swap cmd+d and ctrl+d: cmd+d sends EOF, ctrl+d splits right
keybind = cmd+d=text:\x04
keybind = ctrl+d=new_split:right

# Bind cmd+shift+c to copy and cmd+shift+v to paste
keybind = performable:cmd+shift+c=copy_to_clipboard
keybind = performable:cmd+shift+v=paste_from_clipboard

# Map cmd+r to search history (same as ctrl+r)
keybind = cmd+r=text:\x12

# Tab navigation
keybind = cmd+shift+arrow_right=next_tab
keybind = cmd+shift+arrow_left=previous_tab
keybind = alt+shift+arrow_right=next_tab
keybind = alt+shift+arrow_left=previous_tab
